# Database
DATABASE_URL=sqlite+aiosqlite:///./agrovibe.db

# JWT
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# Media directories (relative to project root)
MEDIA_RAW_DIR=./media/raw
MEDIA_PROCESSED_DIR=./media/processed

# OpenAI
OPENAI_API_KEY=sk-your-openai-key

# Meta / Instagram
META_ACCESS_TOKEN=your-meta-access-token
META_INSTAGRAM_ID=your-instagram-business-id
META_API_VERSION=v22.0
META_BASE_URL=https://graph.facebook.com

# Google OAuth2
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
